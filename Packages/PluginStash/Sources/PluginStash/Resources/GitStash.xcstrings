    "Applying, popping, or branching from a stash may conflict with your current working tree changes. Consider committing first or creating another stash.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applying, popping, or branching from a stash may conflict with your current working tree changes. Consider committing first or creating another stash."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "应用、弹出或从 stash 创建分支可能与当前工作树更改冲突。建议先提交或创建另一个 stash。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "套用、彈出或從 stash 建立分支可能與目前工作樹變更衝突。建議先提交或建立另一個 stash。"
          }
        }
      }
    },
    "Are you sure you want to delete stash@{%lld}? This action cannot be undone.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete stash@{%lld}? This action cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除 stash@{%lld} 吗？此操作无法撤销。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除 stash@{%lld} 嗎？此操作無法復原。"
          }
        }
      }
    },
