    "This will combine \\(commitIndex + 1) commits from HEAD to this commit into one. Only recommended for unpushed commits.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This will combine \\(commitIndex + 1) commits from HEAD to this commit into one. Only recommended for unpushed commits."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这将从 HEAD 到此提交的 \\(commitIndex + 1) 个提交合并为一个。仅建议用于未推送的提交。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這將從 HEAD 到此提交的 \\(commitIndex + 1) 個提交合併為一個。僅建議用於未推送的提交。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "這將從 HEAD 到此提交的 \\(commitIndex + 1) 個提交合併為一個。僅建議用於未推送的提交。"
          }
        }
      }
    },
