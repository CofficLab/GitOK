    "Are you sure you want to discard all changes? This will affect %@. This action cannot be undone.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to discard all changes? This will affect %@. This action cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要丢弃所有更改吗？这会影响 %@。此操作无法撤销。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要捨棄所有變更嗎？這會影響 %@。此操作無法復原。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要捨棄所有變更嗎？這會影響 %@。此操作無法復原。"
          }
        }
      }
    },
