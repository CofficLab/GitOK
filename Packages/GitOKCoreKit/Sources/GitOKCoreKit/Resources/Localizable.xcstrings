    "GitOK will create a new reverse commit to undo the changes. Suitable for pushed commits. If there are conflicts, resolve them manually before continuing.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK will create a new reverse commit to undo the changes. Suitable for pushed commits. If there are conflicts, resolve them manually before continuing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 将创建一个新的反向提交来撤销更改。适用于已推送的提交。如有冲突，请手动解决后再继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 將建立一個新的反向提交來復原變更。適用於已推送的提交。如有衝突，請手動解決後再繼續。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 將建立一個新的反向提交來復原變更。適用於已推送的提交。如有衝突，請手動解決後再繼續。"
          }
        }
      }
    },
    "HEAD will move to this commit. Changes from subsequent commits will be preserved in the staging area.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD will move to this commit. Changes from subsequent commits will be preserved in the staging area."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD 将移动到此提交。后续提交的更改将保留在暂存区中。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD 將移動到此提交。後續提交的變更將保留在暫存區中。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD 將移動到此提交。後續提交的變更將保留在暫存區中。"
          }
        }
      }
    },
    "HEAD will move to this commit. Changes from subsequent commits will be preserved in the working directory but unstaged.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD will move to this commit. Changes from subsequent commits will be preserved in the working directory but unstaged."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD 将移动到此提交。后续提交的更改将保留在工作目录中但取消暂存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD 將移動到此提交。後續提交的變更將保留在工作目錄中但取消暫存。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD 將移動到此提交。後續提交的變更將保留在工作目錄中但取消暫存。"
          }
        }
      }
    },
    "HEAD, staging area, and working directory will all revert to this commit. Local commits and uncommitted changes after this commit will be discarded.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD, staging area, and working directory will all revert to this commit. Local commits and uncommitted changes after this commit will be discarded."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "HEAD、暂存区和工作目录都将恢复到此提交。此提交之后的本地提交和未提交更改将被丢弃。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
