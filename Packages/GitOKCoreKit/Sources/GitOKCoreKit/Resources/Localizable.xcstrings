    "GitOK cannot directly read the SSH passphrase for the current Git operation. Add the key to ssh-agent or macOS Keychain, then retry.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK cannot directly read the SSH passphrase for the current Git operation. Add the key to ssh-agent or macOS Keychain, then retry."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 无法在当前 Git 操作中直接读取 SSH passphrase。请把密钥加入 ssh-agent 或 macOS Keychain，然后重试。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 無法在目前 Git 操作中直接讀取 SSH passphrase。請把密鑰加入 ssh-agent 或 macOS Keychain，然後重試。"
          }
        }
      }
    },
