    "After undoing, the file changes from this commit will be kept in the working directory for re-editing and committing.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "After undoing, the file changes from this commit will be kept in the working directory for re-editing and committing."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "撤销后，此提交的文件更改将保留在工作目录中，可重新编辑并提交。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "復原後，此提交的檔案變更將保留在工作目錄中，可重新編輯並提交。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "復原後，此提交的檔案變更將保留在工作目錄中，可重新編輯並提交。"
          }
        }
      }
    },
