    "GitOK is updating the repository. Other actions are temporarily blocked." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GitOK is updating the repository. Other actions are temporarily blocked."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GitOK 正在更新仓库，其他操作已暂时阻止。"
