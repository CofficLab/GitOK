    "Are you sure you want to delete local branch \"%@\"? Git will prevent deleting unmerged branches.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to delete local branch \"%@\"? Git will prevent deleting unmerged branches."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除本地分支\"%@\"\"吗？Git 会阻止删除未合并的分支。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除本機分支「%@」嗎？Git 會阻止刪除未合併的分支。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "確定要刪除本機分支「%@」嗎？Git 會阻止刪除未合併的分支。"
          }
        }
      }
    },
