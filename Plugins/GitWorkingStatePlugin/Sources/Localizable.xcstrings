    "GitOK saves credentials through the current Git credential helper; platforms like GitHub/GitLab usually require tokens." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GitOK saves credentials through the current Git credential helper; platforms like GitHub/GitLab usually require tokens."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GitOK 会通过当前 Git credential helper 保存凭据；GitHub/GitLab 等平台通常需要 token。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "GitOK 會透過目前的 Git credential helper 儲存憑證；GitHub/GitLab 等平台通常需要 token。"
