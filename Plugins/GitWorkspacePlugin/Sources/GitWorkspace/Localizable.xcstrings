    "GitOK 会通过当前 Git credential helper 保存凭据；GitHub/GitLab 等平台通常需要 token。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK saves credentials via the current Git credential helper; platforms like GitHub/GitLab usually require a token."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 会通过当前 Git credential helper 保存凭据；GitHub/GitLab 等平台通常需要 token。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 會透過目前 Git credential helper 儲存憑證；GitHub/GitLab 等平台通常需要 token。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 會透過目前 Git credential helper 儲存憑證；GitHub/GitLab 等平台通常需要 token。"
          }
        }
      }
    },
