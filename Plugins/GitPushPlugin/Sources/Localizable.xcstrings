    "Cannot push because the remote branch has commits you don't have locally. Please Fetch first, then Pull or Rebase before pushing again.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cannot push because the remote branch has commits you don't have locally. Please Fetch first, then Pull or Rebase before pushing again."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "远程分支有本地没有的提交，无法直接推送。请先获取，再拉取或变基后重试。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "遠端分支有本地沒有的提交，無法直接推送。請先擷取，再拉取或變基後重試。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "远程分支有本地没有的提交，无法直接推送。请先获取，再拉取或变基后重试。"
          }
        }
      }
    },
