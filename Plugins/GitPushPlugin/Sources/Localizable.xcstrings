  "strings": {
    "Branch is up to date, click Fetch to check for remote updates": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Branch is up to date, click Fetch to check for remote updates"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "分支已是最新，点击获取检查远程更新"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "分支已是最新，點擊擷取檢查遠端更新"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "分支已是最新，点击获取检查远程更新"
          }
        }
      }
    },
