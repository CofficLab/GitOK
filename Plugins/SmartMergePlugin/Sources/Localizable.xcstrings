    "This can happen when thousands of files changed or conflicts need to be prepared. Please wait.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This can happen when thousands of files changed or conflicts need to be prepared. Please wait."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当数千个文件发生变化或需要准备冲突信息时，这种情况是正常的，请继续等待。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "當數千個文件發生變化或需要準備衝突資訊時，這種情況是正常的，請繼續等待。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "当数千个文件发生变化或需要准备冲突信息时，这种情况是正常的，请继续等待。"
          }
        }
      }
