    "The helper is still working on this merge. Large conflict sets can take several minutes.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The helper is still working on this merge. Large conflict sets can take several minutes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助进程仍在执行合并。大量冲突文件可能需要几分钟。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "輔助程序仍在執行合併。大量衝突文件可能需要幾分鐘。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "辅助进程仍在执行合并。大量冲突文件可能需要几分钟。"
