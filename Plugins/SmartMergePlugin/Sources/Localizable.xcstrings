    "GitOK is waiting for the helper process to finish. The app is blocked to protect the repository.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK is waiting for the helper process to finish. The app is blocked to protect the repository."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 正在等待辅助进程完成。为保护仓库，App 操作会暂时阻止。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "GitOK 正在等待輔助程序完成。為保護倉庫，App 操作會暫時阻止。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
